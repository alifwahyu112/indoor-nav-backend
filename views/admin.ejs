<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800">

  <div class="flex min-h-screen">

    <aside class="w-64 bg-white shadow-md flex flex-col">
      <div class="p-6 border-b border-gray-200">
        <h1 class="text-2xl font-bold text-blue-600">Dashboard</h1>
      </div>

      <nav class="flex-1 p-4 space-y-2">
        <a href="/" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">👤 Data User</a>
        <a href="/riwayat_perjalanan" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">📍 riwayat_perjalanan</a>
        <a href="/map" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">🗺️ Map</a>
        <a href="/admin" class="block py-2 px-3 rounded-md bg-blue-100 text-blue-700 font-medium">🔑 Data Admin</a>
      </nav>

      <div class="p-4 border-t border-gray-200">
        <a href="/logout" class="text-red-500 hover:underline font-medium">Logout</a>
      </div>
    </aside>

    <main class="flex-1 p-6">

      <header class="flex items-center justify-between mb-6">
        <h2 class="text-3xl font-semibold"><%= title %></h2>
        <div class="relative w-64 md:w-80">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" x2="16.65" y2="16.65"></line></svg>
          </span>
          <input type="text" id="searchInput" onkeyup="searchTable()" placeholder="Cari admin..." class="block w-full pl-10 pr-10 py-2 border border-gray-300 rounded-md leading-5 bg-white placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-blue-500 sm:text-sm">
          <button id="clearSearch" onclick="clearInput()" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 hidden">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </header>

      <form action="/tambah-admin" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-4 bg-white p-6 rounded-lg shadow mb-8">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
            <input type="text" name="username" placeholder="Masukkan Username" class="w-full border p-2 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input type="text" name="password" placeholder="Masukkan Password" class="w-full border p-2 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>
        <div class="flex items-end">
            <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded-md hover:bg-green-700 w-full md:w-auto transition">
              + Tambah Admin
            </button>
        </div>
      </form>

      <div class="bg-white p-6 rounded-lg shadow">
        <h3 class="text-2xl font-semibold mb-4">Daftar Admin</h3>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-gray-200 text-sm">
            <thead>
              <tr class="bg-blue-50 text-left text-gray-700">
                <th class="border px-4 py-2 w-10">ID</th>
                <th class="border px-4 py-2">Username</th>
                <th class="border px-4 py-2">Password</th>
                <th class="border px-4 py-2 text-center w-24">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (admins && admins.length > 0) { %>
                  <% admins.forEach(admin => { %>
                    <tr class="hover:bg-gray-50 transition">
                      <td class="border px-4 py-2 text-center"><%= admin.id %></td>
                      <td class="border px-4 py-2 font-medium"><%= admin.username %></td>
                      <td class="border px-4 py-2">******</td>
                      <td class="border px-4 py-2 text-center">
                        <button type="button" onclick="bukaModalHapus('/delete-admin/<%= admin.id %>')" class="text-red-500 hover:underline font-medium">Hapus</button>
                      </td>
                    </tr>
                  <% }) %>
              <% } else { %>
                  <tr>
                      <td colspan="4" class="text-center py-8 text-gray-500">
                        <p class="text-lg">📂 Belum ada data admin.</p>
                      </td>
                  </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <div id="modalHapus" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-gray-900 bg-opacity-40 backdrop-blur-sm" onclick="tutupModalHapus()"></div>
    <div class="bg-white text-gray-800 rounded-xl shadow-2xl max-w-sm w-full mx-4 p-6 relative z-10 border border-gray-200">
      <div class="flex items-center space-x-3 text-red-600 mb-3">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
        <h3 class="text-lg font-bold tracking-tight">Hapus Akun Admin</h3>
      </div>
      <p class="text-gray-600 text-sm mb-6 leading-relaxed">
        Apakah Anda yakin ingin menghapus hak akses akun administrator ini secara permanen?
      </p>
      <div class="flex space-x-3 justify-end text-sm font-semibold">
        <button type="button" onclick="tutupModalHapus()" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition border border-gray-200">Batal</button>
        <a id="linkEksekusiHapus" href="#" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition shadow-md shadow-red-200">Hapus Selamanya</a>
      </div>
    </div>
  </div>

  <script>
    function bukaModalHapus(urlDelete) {
      document.getElementById("linkEksekusiHapus").href = urlDelete;
      document.getElementById("modalHapus").classList.remove("hidden");
    }
    function tutupModalHapus() {
      document.getElementById("modalHapus").classList.add("hidden");
      document.getElementById("linkEksekusiHapus").href = "#";
    }

    function searchTable() {
      const input = document.getElementById("searchInput");
      const clearBtn = document.getElementById("clearSearch");
      const filter = input.value.toLowerCase();
      if (input.value.length > 0) { clearBtn.classList.remove('hidden'); } else { clearBtn.classList.add('hidden'); }
      const table = document.querySelector("table tbody");
      const tr = table.getElementsByTagName("tr");
      for (let i = 0; i < tr.length; i++) {
        if (tr[i].cells.length < 2) continue;
        let match = false;
        const td = tr[i].getElementsByTagName("td");
        for (let j = 0; j < td.length; j++) {
          if (td[j]) {
            const textValue = td[j].textContent || td[j].innerText;
            if (textValue.toLowerCase().indexOf(filter) > -1) { match = true; break; }
          }
        }
        tr[i].style.display = match ? "" : "none";
      }
    }
    function clearInput() {
      const input = document.getElementById("searchInput");
      input.value = "";
      searchTable();
      input.focus();
    }
  </script>
</body>
</html>