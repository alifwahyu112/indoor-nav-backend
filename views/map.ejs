<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800">

  <div class="flex h-screen overflow-hidden">

    <aside class="w-64 bg-white shadow-md flex flex-col z-10">
      <div class="p-6 border-b border-gray-200">
        <h1 class="text-2xl font-bold text-blue-600">Dashboard</h1>
      </div>
      <nav class="flex-1 p-4 space-y-2">
        <a href="/" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">👤 Data User</a>
        <a href="/riwayat_perjalanan" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">📍 Riwayat</a>
        <a href="/map" class="block py-2 px-3 rounded-md bg-blue-100 text-blue-700 font-medium">🗺️ Map</a>
        <a href="/admin" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">🔑 Admin</a>
      </nav>
      <div class="p-4 border-t border-gray-200">
        <a href="/logout" class="text-red-500 hover:underline font-medium">Logout</a>
      </div>
    </aside>

    <main class="flex-1 h-full overflow-y-auto p-6 bg-gray-100">

      <header class="flex items-center justify-between mb-6">
        <h2 class="text-3xl font-semibold"><%= title %></h2>
        <div class="relative w-64 md:w-80">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </span>
          <input type="text" id="searchInput" onkeyup="searchTable()" placeholder="Cari data map..." class="block w-full pl-10 pr-10 py-2 border border-gray-300 rounded-md leading-5 bg-white placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-blue-500 sm:text-sm">
          <button id="clearSearch" onclick="clearInput()" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 hidden">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </header>

      <div class="bg-white p-6 rounded-lg shadow mb-10">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-2xl font-semibold">Daftar Data Map</h3>
          <button onclick="openAddModal()" class="bg-green-600 text-white px-4 py-2 rounded-md hover:bg-green-700 font-bold transition shadow-sm flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Tambah Map
          </button>
        </div>

        <div class="overflow-x-auto rounded-t-lg border border-gray-200 border-b-0">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-blue-50 text-left border-b border-gray-200">
                <th class="px-4 py-3 font-semibold text-gray-700">ID</th>
                <th class="px-4 py-3 font-semibold text-gray-700">Floor_ID</th>
                <th class="px-4 py-3 font-semibold text-gray-700">Room Name</th>
                <th class="px-4 py-3 font-semibold text-gray-700">Coordinates</th>
                <th class="px-4 py-3 font-semibold text-gray-700">room_id</th>
                <th class="px-4 py-3 font-semibold text-gray-700">Denah BIM</th>
                <th class="px-4 py-3 font-semibold text-gray-700 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody id="tableBody">
              <% if (maps && maps.length > 0) { %>
                <% maps.forEach(map => { %>
                  <tr class="data-row hover:bg-gray-50 border-b border-gray-100 transition-colors">
                    <td class="px-4 py-3 font-bold"><%= map.id_map %></td>
                    <td class="px-4 py-3"><%= map.Floor_ID %></td>
                    <td class="px-4 py-3"><%= map.room_name %></td>
                    <td class="px-4 py-3 font-mono text-xs text-blue-600"><%= map.coordinates %></td>
                    <td class="px-4 py-3 font-semibold"><%= map.room_id %></td>

                    <td class="px-4 py-3">
                      <% if (map.bim_image && map.bim_image.trim() !== "") { %>
                        <a href="/viewer?model=<%= encodeURIComponent(map.bim_image) %>&roomId=<%= map.room_id %>&roomName=<%= encodeURIComponent(map.room_name) %>&coords=<%= encodeURIComponent(map.coordinates) %>" target="_blank" class="bg-blue-500 text-white px-2 py-1 rounded hover:bg-blue-600 text-xs font-semibold inline-block">👁️ Lihat BIM 3D</a>
                      <% } else { %>
                        <span class="text-gray-400 italic text-xs">Belum ada denah</span>
                      <% } %>
                    </td>

                    <td class="px-4 py-3 text-center space-x-2 whitespace-nowrap">
                      <button onclick="openEditModal('<%= map.id_map %>', '<%= map.Floor_ID %>', '<%= map.room_name %>', '<%= map.coordinates %>', '<%= map.room_id %>', '<%= map.bim_image %>')" class="bg-blue-100 text-blue-600 px-3 py-1.5 rounded-md hover:bg-blue-200 text-xs font-bold transition-colors">Edit</button>
                      <button type="button" onclick="bukaModalHapus('<%= map.id_map %>', '<%= map.room_name %>', '<%= map.room_id %>')" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-md hover:bg-red-200 text-xs font-bold transition-colors">Hapus</button>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr class="empty-row">
                  <td colspan="7" class="text-center py-10 text-gray-500 italic">Belum ada data map.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-between border border-gray-200 bg-gray-50 px-4 py-3 rounded-b-lg">
          <div class="flex items-center space-x-2 text-sm text-gray-600 mb-3 sm:mb-0">
            <span>Tampilkan</span>
            <select id="rowsPerPage" onchange="changeRowsPerPage()" class="border border-gray-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500 py-1.5 pl-2 pr-6 bg-white outline-none cursor-pointer">
              <option value="5">5</option>
              <option value="10" selected>10</option>
              <option value="20">20</option>
              <option value="50">50</option>
            </select>
            <span>baris</span>
          </div>

          <div class="flex items-center space-x-4">
            <span class="text-sm text-gray-600" id="pageInfo">
              Menampilkan <span class="font-semibold text-gray-900" id="startRow">0</span> - <span class="font-semibold text-gray-900" id="endRow">0</span> dari <span class="font-semibold text-gray-900" id="totalRowsText">0</span>
            </span>
            <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
              <button id="prevBtn" onclick="prevPage()" class="relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-100 focus:z-20 focus:outline-offset-0 disabled:opacity-50 disabled:cursor-not-allowed bg-white transition-all">
                <span class="sr-only">Previous</span>
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" /></svg>
              </button>
              <button id="nextBtn" onclick="nextPage()" class="relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-100 focus:z-20 focus:outline-offset-0 disabled:opacity-50 disabled:cursor-not-allowed bg-white transition-all">
                <span class="sr-only">Next</span>
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
              </button>
            </nav>
          </div>
        </div>
        </div>
    </main>
  </div>

  <div id="addModal" class="fixed inset-0 bg-gray-900 bg-opacity-60 hidden overflow-y-auto h-full w-full z-50 flex justify-center items-center">
    <div class="bg-white p-6 rounded-lg shadow-2xl w-full max-w-md mx-4 transform transition-all relative">
      <div class="flex justify-between items-center mb-5 border-b pb-3 border-gray-200">
        <h3 class="text-xl font-bold text-gray-800">Tambah Titik Map Baru</h3>
        <button onclick="closeAddModal()" class="text-gray-400 hover:text-gray-600 text-2xl font-bold leading-none">&times;</button>
      </div>
      <form action="/tambah-map" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Floor ID</label>
          <input type="text" name="Floor_ID" placeholder="e.g. ground" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-green-500 outline-none" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Nama Ruangan</label>
          <input type="text" name="room_name" placeholder="Masukkan Nama Ruangan" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-green-500 outline-none" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Coordinates (x,y,z)</label>
          <input type="text" name="coordinates" placeholder="-74.4,0.444,-59.75" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-green-500 outline-none" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Room ID (Unique)</label>
          <input type="text" name="room_id" placeholder="e.g. MBPJS" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-green-500 outline-none" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Link URL Denah BIM (Opsional)</label>
          <input type="text" name="bim_image" placeholder="https://..." class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-green-500 outline-none">
        </div>
        <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200 mt-4">
          <button type="button" onclick="closeAddModal()" class="bg-gray-500 text-white px-4 py-2 rounded-md hover:bg-gray-600 transition font-medium">Batal</button>
          <button type="submit" class="bg-green-600 text-white px-5 py-2 rounded-md hover:bg-green-700 font-bold shadow-md transition">Simpan Map</button>
        </div>
      </form>
    </div>
  </div>

  <div id="editModal" class="fixed inset-0 bg-gray-900 bg-opacity-60 hidden overflow-y-auto h-full w-full z-50 flex justify-center items-center">
    <div class="bg-white p-8 rounded-lg shadow-2xl w-full max-w-md mx-4 transform transition-all relative">
      <div class="flex justify-between items-center mb-6 border-b pb-3 border-gray-200">
        <h3 class="text-xl font-bold text-gray-800">Edit Data Map</h3>
        <button onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600 text-2xl font-bold leading-none">&times;</button>
      </div>
      <form action="/update-map" method="POST" class="space-y-4">
        <input type="hidden" id="edit_id_map" name="id_map">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Floor ID</label>
          <input type="text" id="edit_Floor_ID" name="Floor_ID" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-blue-500 outline-none" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Room Name</label>
          <input type="text" id="edit_room_name" name="room_name" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-blue-500 outline-none" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Coordinates (x,y,z)</label>
          <input type="text" id="edit_coordinates" name="coordinates" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-blue-500 outline-none" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Room ID (Internal)</label>
          <input type="text" id="edit_room_id" name="room_id" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-blue-500 outline-none" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Link URL Denah BIM</label>
          <input type="text" id="edit_bim_image" name="bim_image" class="w-full border border-gray-300 p-2 rounded-md focus:ring-2 focus:ring-blue-500 outline-none" placeholder="https://...">
        </div>
        <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200 mt-4">
          <button type="button" onclick="closeEditModal()" class="bg-gray-500 text-white px-4 py-2 rounded-md hover:bg-gray-600 transition font-medium">Batal</button>
          <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-md hover:bg-blue-700 font-bold shadow-md transition">Update</button>
        </div>
      </form>
    </div>
  </div>

  <div id="modalHapus" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-gray-900 bg-opacity-40 backdrop-blur-sm" onclick="tutupModalHapus()"></div>
    <div class="bg-white text-gray-800 rounded-xl shadow-2xl max-w-md w-full mx-4 p-6 relative z-10 border border-gray-200">
      <div class="flex items-center space-x-3 text-red-600 mb-3">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
        <h3 class="text-xl font-bold tracking-tight">Hapus Titik Map</h3>
      </div>
      <p class="text-gray-600 text-sm mb-4 leading-relaxed">
        Anda akan menghapus secara permanen data titik map ruangan <span id="namaRuanganModal" class="font-bold text-gray-900 underline decoration-red-500 decoration-2"></span>. Tindakan ini <span class="text-red-600 font-semibold">tidak dapat dibatalkan</span>.
      </p>
      <div class="bg-red-50 border border-red-200 text-red-800 p-3 rounded-lg text-xs mb-5 flex items-start space-x-2">
        <span class="text-base leading-none">⚠️</span>
        <span>Titik lokasi ruangan beserta koordinat penunjuk jalan AR ini akan hilang sepenuhnya dari sistem.</span>
      </div>
      <div class="mb-6">
        <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wider">
          Ketik Room ID <span id="roomTargetLabel" class="text-red-600 font-black bg-red-50 px-1.5 py-0.5 rounded border border-red-200 font-sans"></span> untuk mengonfirmasi:
        </label>
        <input
          type="text"
          id="inputKonfirmasiHapus"
          onkeyup="validasiTeksHapus()"
          placeholder="Masukkan Room ID (e.g. MBPJS)"
          class="w-full bg-gray-50 border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 font-semibold tracking-wide"
          autocomplete="off"
        >
      </div>
      <div class="flex space-x-3 justify-end text-sm font-semibold">
        <button type="button" onclick="tutupModalHapus()" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-all border border-gray-200">Batal</button>
        <a id="linkEksekusiHapus" href="#" class="px-4 py-2 bg-gray-200 text-gray-400 rounded-lg pointer-events-none cursor-not-allowed transition-all inline-flex items-center shadow-sm">Hapus Selamanya</a>
      </div>
    </div>
  </div>

  <script>
    // --- FUNGSI MODAL TAMBAH & EDIT MAP ---
    function openAddModal() {
      document.getElementById('addModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden'; 
    }
    function closeAddModal() {
      document.getElementById('addModal').classList.add('hidden');
      document.body.style.overflow = 'auto'; 
    }

    function openEditModal(id, floor, name, coords, rid, bimImage) {
      document.getElementById('edit_id_map').value = id;
      document.getElementById('edit_Floor_ID').value = floor;
      document.getElementById('edit_room_name').value = name;
      document.getElementById('edit_coordinates').value = coords;
      document.getElementById('edit_room_id').value = rid;
      document.getElementById('edit_bim_image').value = (bimImage && bimImage !== 'undefined') ? bimImage : '';
      document.getElementById('editModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeEditModal() {
      document.getElementById('editModal').classList.add('hidden');
      document.body.style.overflow = 'auto';
    }

    // --- FUNGSI MODAL HAPUS MAP ---
    let mapIdYangAkanDihapus = null;
    let roomIdTargetPencocokan = "";

    function bukaModalHapus(id_map, roomName, room_id) {
      mapIdYangAkanDihapus = id_map;
      roomIdTargetPencocokan = room_id;
      document.getElementById("namaRuanganModal").innerText = roomName;
      document.getElementById("roomTargetLabel").innerText = room_id;
      document.getElementById("modalHapus").classList.remove("hidden");
      document.getElementById("inputKonfirmasiHapus").focus();
    }

    function tutupModalHapus() {
      document.getElementById("modalHapus").classList.add("hidden");
      document.getElementById("inputKonfirmasiHapus").value = "";
      const btnHapus = document.getElementById("linkEksekusiHapus");
      btnHapus.classList.remove("bg-red-600", "text-white", "hover:bg-red-700", "shadow-md");
      btnHapus.classList.add("bg-gray-200", "text-gray-400", "pointer-events-none", "cursor-not-allowed");
      btnHapus.href = "#";
      mapIdYangAkanDihapus = null;
      roomIdTargetPencocokan = "";
    }

    function validasiTeksHapus() {
      const textInput = document.getElementById("inputKonfirmasiHapus").value;
      const btnHapus = document.getElementById("linkEksekusiHapus");
      if (textInput.trim() === roomIdTargetPencocokan) {
        btnHapus.classList.remove("bg-gray-200", "text-gray-400", "pointer-events-none", "cursor-not-allowed");
        btnHapus.classList.add("bg-red-600", "text-white", "hover:bg-red-700", "shadow-md", "shadow-red-200");
        btnHapus.href = '/delete-map/' + mapIdYangAkanDihapus;
      } else {
        btnHapus.classList.remove("bg-red-600", "text-white", "hover:bg-red-700", "shadow-md", "shadow-red-200");
        btnHapus.classList.add("bg-gray-200", "text-gray-400", "pointer-events-none", "cursor-not-allowed");
        btnHapus.href = "#";
      }
    }

    // --- SCRIPT PAGINATION & SEARCH ---
    let currentPage = 1;
    let rowsPerPage = 10;
    let allRows = [];
    let filteredRows = [];

    document.addEventListener("DOMContentLoaded", () => {
      const tbody = document.getElementById("tableBody");
      allRows = Array.from(tbody.getElementsByClassName("data-row"));
      filteredRows = [...allRows]; 
      renderTable();
    });

    function renderTable() {
      const totalRows = filteredRows.length;
      const totalPages = Math.ceil(totalRows / rowsPerPage) || 1;

      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      const startIndex = (currentPage - 1) * rowsPerPage;
      const endIndex = Math.min(startIndex + rowsPerPage, totalRows);

      allRows.forEach(row => row.style.display = "none");

      for (let i = startIndex; i < endIndex; i++) {
        if (filteredRows[i]) {
          filteredRows[i].style.display = "";
        }
      }

      updatePaginationUI(startIndex, endIndex, totalRows, totalPages);
    }

    function updatePaginationUI(start, end, total, totalPages) {
      document.getElementById("startRow").innerText = total === 0 ? 0 : start + 1;
      document.getElementById("endRow").innerText = end;
      document.getElementById("totalRowsText").innerText = total;

      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");

      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage === totalPages || total === 0;
    }

    function nextPage() { currentPage++; renderTable(); }
    function prevPage() { currentPage--; renderTable(); }
    
    function changeRowsPerPage() {
      const select = document.getElementById("rowsPerPage");
      rowsPerPage = parseInt(select.value);
      currentPage = 1; 
      renderTable();
    }

    function searchTable() {
      const input = document.getElementById("searchInput");
      const clearBtn = document.getElementById("clearSearch");
      const filter = input.value.toLowerCase();
      
      input.value.length > 0 ? clearBtn.classList.remove('hidden') : clearBtn.classList.add('hidden');

      filteredRows = allRows.filter(row => {
        let match = false;
        const td = row.getElementsByTagName("td");
        for (let j = 0; j < td.length; j++) {
          if (td[j]) {
            const textValue = td[j].textContent || td[j].innerText;
            if (textValue.toLowerCase().indexOf(filter) > -1) {
              match = true;
              break;
            }
          }
        }
        return match;
      });

      currentPage = 1; 
      renderTable();
    }

    function clearInput() {
      const input = document.getElementById("searchInput");
      input.value = "";
      searchTable();
      input.focus();
    }

    // Menutup semua modal jika area abu-abu (background) diklik
    window.onclick = function(event) {
      const editModal = document.getElementById('editModal');
      const addModal = document.getElementById('addModal');
      if (event.target == editModal) { closeEditModal(); }
      if (event.target == addModal) { closeAddModal(); }
    }
  </script>
</body>
</html>