<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    body { margin: 0; padding: 0; overflow: hidden; background-color: #e0e6ed; font-family: sans-serif; }
    #myCanvas { width: 100vw; height: 100vh; display: block; }
    #loading {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-weight: bold; font-size: 20px;
      color: #3b82f6; z-index: 10; text-align: center;
    }
    #roomLabel {
      position: absolute; top: 16px; left: 50%;
      transform: translateX(-50%);
      background: rgba(30,30,30,0.75);
      color: white; padding: 8px 20px;
      border-radius: 20px; font-size: 15px;
      z-index: 20; display: none;
      font-weight: bold; letter-spacing: 0.5px;
    }
    #btnBack {
      position: absolute; top: 16px; left: 16px;
      background: white; border: none;
      padding: 8px 14px; border-radius: 8px;
      cursor: pointer; font-weight: bold;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
      z-index: 20; font-size: 14px;
    }
    #btnBack:hover { background: #f0f0f0; }
    #infoBox {
      position: absolute; bottom: 24px; left: 50%;
      transform: translateX(-50%);
      background: rgba(30,30,30,0.7);
      color: #ccc; padding: 6px 16px;
      border-radius: 12px; font-size: 12px;
      z-index: 20; display: none;
    }
  </style>
</head>
<body>
  <button id="btnBack" onclick="history.back()">← Kembali</button>
  <div id="roomLabel"></div>
  <div id="infoBox"></div>
  <div id="loading">⏳ Memuat Model BIM 3D...</div>
  <canvas id="myCanvas"></canvas>

  <script type="module">
    import { Viewer } from "https://esm.sh/@xeokit/xeokit-sdk/src/viewer/Viewer.js";
    import { XKTLoaderPlugin } from "https://esm.sh/@xeokit/xeokit-sdk/src/plugins/XKTLoaderPlugin/XKTLoaderPlugin.js";

    const params    = new URLSearchParams(window.location.search);
    const urlModel  = params.get("model") || "<%- modelUrl %>";
    const roomId    = params.get("roomId") || "";
    const roomName  = params.get("roomName") || roomId;
    const coordsRaw = params.get("coords") || "";

    const loadingEl = document.getElementById("loading");
    const roomLabel = document.getElementById("roomLabel");
    const infoBox   = document.getElementById("infoBox");

    function parseCoords(str) {
      if (!str || str.trim() === "") return null;
      const parts = str.split(",").map(s => parseFloat(s.trim()));
      if (parts.length >= 3 && !parts.some(isNaN)) {
        return { x: parts[0], y: parts[1], z: parts[2] };
      }
      return null;
    }

    // Konversi koordinat Unity ke koordinat xeokit
    // AABB xeokit: X[-16.84 ~ 50.19], Y[-0.02 ~ 5.33], Z[-84.96 ~ 0.06]
    // Koordinat Unity range: X[-100 ~ 0], Z[-100 ~ 0]
    function unityToXeokit(ux, uy, uz) {
      // Range Unity (berdasarkan data koordinat di database)
      const unityMinX = -100, unityMaxX = 0;
      const unityMinZ = -100, unityMaxZ = 0;

      // Range xeokit (dari AABB model)
      const xeoMinX = -16.84, xeoMaxX = 50.19;
      const xeoMinZ = -84.96, xeoMaxZ = 0.06;
      const xeoMidY = 2.65; // center Y model

      // Normalisasi Unity ke 0-1 lalu map ke xeokit
      const ratioX = (ux - unityMinX) / (unityMaxX - unityMinX);
      const ratioZ = (uz - unityMinZ) / (unityMaxZ - unityMinZ);

      const xeoX = xeoMinX + ratioX * (xeoMaxX - xeoMinX);
      const xeoZ = xeoMinZ + ratioZ * (xeoMaxZ - xeoMinZ);

      return { x: xeoX, y: xeoMidY, z: xeoZ };
    }

    try {
      const viewer = new Viewer({ canvasId: "myCanvas", transparent: true });
      const xktLoader = new XKTLoaderPlugin(viewer);

      if (!urlModel || urlModel.trim() === "") {
        loadingEl.innerText = "❌ File BIM tidak ditemukan!";
        loadingEl.style.color = "red";
      } else {
        const model = xktLoader.load({
          id: "BIM_MODEL",
          src: urlModel,
          edges: false
        });

        model.on("loaded", () => {
          loadingEl.style.display = "none";

          const coords = parseCoords(coordsRaw);

          if (coords) {
            // Konversi koordinat Unity ke xeokit
            const target = unityToXeokit(coords.x, coords.y, coords.z);

            console.log("Unity coords:", coords);
            console.log("Xeokit target:", target);

            // Jarak kamera = 10 unit (proporsional model)
            const camDist = 10;

            viewer.cameraFlight.flyTo({
              eye:  [target.x,           target.y + camDist, target.z + camDist],
              look: [target.x,           target.y,           target.z],
              up:   [0, 1, 0],
              duration: 1.5
            });

            roomLabel.innerText = "📍 " + roomName;
            roomLabel.style.display = "block";
            infoBox.innerText = "📌 " + coordsRaw;
            infoBox.style.display = "block";

          } else {
            viewer.cameraFlight.flyTo({
              aabb: model.aabb,
              duration: 0.5
            });
            if (roomName) {
              roomLabel.innerText = "📍 " + roomName;
              roomLabel.style.display = "block";
            }
          }
        });

        model.on("error", (errMsg) => {
          console.error("Error:", errMsg);
          loadingEl.innerText = "❌ Gagal memuat file BIM!";
          loadingEl.style.color = "red";
        });
      }

    } catch (err) {
      console.error("Xeokit Error:", err);
      loadingEl.innerText = "❌ Error Sistem Viewer 3D!";
      loadingEl.style.color = "red";
    }
  </script>
</body>
</html>