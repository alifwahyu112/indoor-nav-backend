<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    body { margin: 0; padding: 0; overflow: hidden; background-color: #e0e6ed; font-family: sans-serif; }
    #myCanvas { width: 100vw; height: 100vh; display: block; }
    #loading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-weight: bold; font-size: 20px; color: #3b82f6; z-index: 10; }
  </style>
</head>
<body>
  
  <div id="loading">Memuat Model BIM 3D...</div>
  <canvas id="myCanvas"></canvas>

  <script type="module">
    // JURUS PAMUNGKAS: Tembak langsung ke source internal agar esm.sh me-resolve dependensi secara otomatis
    import { Viewer } from "https://esm.sh/@xeokit/xeokit-sdk/src/viewer/Viewer.js";
    import { XKTLoaderPlugin } from "https://esm.sh/@xeokit/xeokit-sdk/src/plugins/XKTLoaderPlugin/XKTLoaderPlugin.js";

    try {
      // Inisialisasi Canvas
      const viewer = new Viewer({
        canvasId: "myCanvas",
        transparent: true
      });

      // Panggil Plugin untuk membaca format .xkt
      const xktLoader = new XKTLoaderPlugin(viewer);

      // Ambil Link Model dari parameter URL server Node.js lu
      const urlModel = "<%- modelUrl %>";

      if (urlModel && urlModel.trim() !== "") {
        console.log("Mencoba memuat model dari:", urlModel);
        
        const model = xktLoader.load({
          id: "TOWER_MODEL",
          src: urlModel,
          edges: false // Dimatikan karena triangles terlalu padat sesuai warning terminal tadi
        });

        model.on("loaded", () => {
          console.log("Model 3D Berhasil Dimuat Sempurna!");
          document.getElementById("loading").style.display = "none";
          
          // Paksa kamera terbang fokus ke tengah-tengah objek bangunan
          viewer.cameraFlight.flyTo({
            aabb: model.aabb,
            duration: 0.5
          });
        });
        
        model.on("error", (errMsg) => {
          console.error("Error loading model:", errMsg);
          document.getElementById("loading").innerText = "❌ Gagal memuat file BIM!";
          document.getElementById("loading").style.color = "red";
        });
        
      } else {
        document.getElementById("loading").innerText = "❌ File BIM tidak ditemukan atau Link kosong!";
        document.getElementById("loading").style.color = "red";
      }
    } catch (err) {
      console.error("Xeokit Initialization Error:", err);
      document.getElementById("loading").innerText = "❌ Error Sistem Viewer 3D!";
      document.getElementById("loading").style.color = "red";
    }
  </script>
</body>
</html>