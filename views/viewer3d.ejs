<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    body { margin: 0; padding: 0; overflow: hidden; background-color: #e0e6ed; font-family: sans-serif; }
    #myCanvas { width: 100vw; height: 100vh; display: block; }
    #loading {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-weight: bold; font-size: 20px;
      color: #3b82f6; z-index: 10; text-align: center;
    }
    #roomLabel {
      position: absolute; top: 16px; left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.65);
      color: white; padding: 6px 18px;
      border-radius: 20px; font-size: 14px;
      z-index: 20; display: none;
      font-weight: bold; letter-spacing: 0.5px;
    }
    #btnBack {
      position: absolute; top: 16px; left: 16px;
      background: white; border: none;
      padding: 8px 14px; border-radius: 8px;
      cursor: pointer; font-weight: bold;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
      z-index: 20; font-size: 14px;
    }
    #btnBack:hover { background: #f0f0f0; }
  </style>
</head>
<body>
  <button id="btnBack" onclick="history.back()">← Kembali</button>
  <div id="roomLabel"></div>
  <div id="loading">⏳ Memuat Model BIM 3D...</div>
  <canvas id="myCanvas"></canvas>

  <script type="module">
    import { Viewer } from "https://esm.sh/@xeokit/xeokit-sdk/src/viewer/Viewer.js";
    import { XKTLoaderPlugin } from "https://esm.sh/@xeokit/xeokit-sdk/src/plugins/XKTLoaderPlugin/XKTLoaderPlugin.js";

    const params   = new URLSearchParams(window.location.search);
    const urlModel = params.get("model") || "<%- modelUrl %>";
    const roomId   = params.get("roomId") || "";

    const loadingEl = document.getElementById("loading");
    const roomLabel = document.getElementById("roomLabel");

    try {
      const viewer = new Viewer({ canvasId: "myCanvas", transparent: true });
      const xktLoader = new XKTLoaderPlugin(viewer);

      if (!urlModel || urlModel.trim() === "") {
        loadingEl.innerText = "❌ File BIM tidak ditemukan!";
        loadingEl.style.color = "red";
      } else {
        const model = xktLoader.load({
          id: "BIM_MODEL",
          src: urlModel,
          edges: false
        });

        model.on("loaded", () => {
          loadingEl.style.display = "none";

          if (roomId && roomId.trim() !== "") {
            const scene = viewer.scene;
            let foundEntityIds = [];

            // Cara 1: cari langsung by ID
            if (scene.objects[roomId]) {
              foundEntityIds.push(roomId);
            }

            // Cara 2: scan semua entity, cocokkan yang mengandung roomId
            if (foundEntityIds.length === 0) {
              const allIds = Object.keys(scene.objects);
              for (const id of allIds) {
                if (id.toUpperCase().includes(roomId.toUpperCase())) {
                  foundEntityIds.push(id);
                }
              }
            }

            if (foundEntityIds.length > 0) {
              // Highlight semua entity yang cocok
              for (const eid of foundEntityIds) {
                const ent = scene.objects[eid];
                if (ent) {
                  ent.highlighted = true;
                  ent.selected = true;
                }
              }

              // Fly kamera ke entity tersebut
              viewer.cameraFlight.flyTo({
                objectIds: foundEntityIds,
                duration: 1.5,
                fit: true,
                fitFOV: 45
              });

              roomLabel.innerText = "📍 " + roomId;
              roomLabel.style.display = "block";

            } else {
              // Entity tidak ketemu, tampilkan seluruh model
              console.warn("Entity tidak ditemukan untuk roomId:", roomId);
              viewer.cameraFlight.flyTo({ aabb: model.aabb, duration: 1.0 });
              roomLabel.innerText = '⚠️ Room "' + roomId + '" tidak ditemukan di model';
              roomLabel.style.display = "block";
              roomLabel.style.background = "rgba(180,80,0,0.75)";
            }

          } else {
            // Tidak ada roomId, tampilkan seluruh model
            viewer.cameraFlight.flyTo({ aabb: model.aabb, duration: 0.5 });
          }
        });

        model.on("error", (errMsg) => {
          console.error("Error:", errMsg);
          loadingEl.innerText = "❌ Gagal memuat file BIM!";
          loadingEl.style.color = "red";
        });
      }

    } catch (err) {
      console.error("Xeokit Error:", err);
      loadingEl.innerText = "❌ Error Sistem Viewer 3D!";
      loadingEl.style.color = "red";
    }
  </script>
</body>
</html>