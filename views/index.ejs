<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800">

  <div class="flex h-screen overflow-hidden">

    <aside class="w-64 bg-white shadow-md flex flex-col z-10">
      <div class="p-6 border-b border-gray-200">
        <h1 class="text-2xl font-bold text-blue-600">Dashboard</h1>
      </div>

      <nav class="flex-1 p-4 space-y-2">
        <a href="/" class="block py-2 px-3 rounded-md bg-blue-100 text-blue-700 font-medium">👤 Data User</a>
        <a href="/riwayat_perjalanan" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">📍 riwayat_perjalanan</a>
        <a href="/map" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">🗺️ Map</a>
        <a href="/admin" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">🔑 Admin</a>
      </nav>

      <div class="p-4 border-t border-gray-200">
        <a href="/logout" class="text-red-500 hover:underline font-medium">Logout</a>
      </div>
    </aside>

    <main class="flex-1 h-full overflow-y-auto p-6 bg-gray-100">

      <header class="flex items-center justify-between mb-6">
        <h2 class="text-3xl font-semibold"><%= title %></h2>

        <div class="relative w-64 md:w-80">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </span>
          
          <input type="text" id="searchInput" onkeyup="searchTable()" placeholder="Cari user (nama, email, bpjs...)" class="block w-full pl-10 pr-10 py-2 border border-gray-300 rounded-md leading-5 bg-white placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-blue-500 sm:text-sm">
          
          <button id="clearSearch" onclick="clearInput()" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 hidden">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </header>

      <form action="/tambah" method="POST" class="grid grid-cols-2 md:grid-cols-4 gap-4 bg-white p-6 rounded-lg shadow">
        <input type="text" name="username" placeholder="Username" class="border p-2 rounded-md" required>
        <input type="password" name="password" placeholder="Password" class="border p-2 rounded-md" required>
        <input type="email" name="gmail" placeholder="Gmail" class="border p-2 rounded-md">
        <input type="text" name="mobile_number" placeholder="Mobile Number" class="border p-2 rounded-md">
        <input type="text" name="BPJS_number" placeholder="BPJS Number" class="border p-2 rounded-md">
        <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded-md hover:bg-green-700 col-span-2 md:col-span-1">
            Tambah
        </button>
      </form>

      <div class="mt-8 bg-white p-6 rounded-lg shadow mb-10">
        <h3 class="text-2xl font-semibold mb-4">Daftar User</h3>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-gray-200 text-sm">
            <thead>
              <tr class="bg-blue-50 text-left">
                <th class="border px-4 py-2">ID</th>
                <th class="border px-4 py-2">Username</th>
                <th class="border px-4 py-2">Password</th>
                <th class="border px-4 py-2">Gmail</th>
                <th class="border px-4 py-2">Mobile</th>
                <th class="border px-4 py-2">BPJS</th>
                <th class="border px-4 py-2 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
                <tr class="hover:bg-gray-50">
                  <td class="border px-4 py-2"><%= user.id %></td>
                  <td class="border px-4 py-2"><%= user.username %></td>
                  <td class="border px-4 py-2 text-gray-400 font-mono tracking-widest">********</td>
                  <td class="border px-4 py-2"><%= user.gmail %></td>
                  <td class="border px-4 py-2"><%= user.mobile_number %></td>
                  <td class="border px-4 py-2"><%= user.BPJS_number %></td>
                  <td class="border px-4 py-2 text-center">
                    <button type="button" onclick="bukaModalHapus('<%= user.id %>', '<%= user.username %>')" class="text-red-500 hover:underline font-medium">Hapus</button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <div id="modalHapus" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-gray-900 bg-opacity-40 backdrop-blur-sm" onclick="tutupModalHapus()"></div>
    
    <div class="bg-white text-gray-800 rounded-xl shadow-2xl max-w-md w-full mx-4 p-6 relative z-10 border border-gray-200">
      <div class="flex items-center space-x-3 text-red-600 mb-3">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
        <h3 class="text-xl font-bold tracking-tight">Konfirmasi Penghapusan</h3>
      </div>
      
      <p class="text-gray-600 text-sm mb-4 leading-relaxed">
        Anda akan menghapus secara permanen pengguna <span id="namaUserModal" class="font-bold text-gray-900 underline decoration-red-500 decoration-2"></span>. Tindakan ini <span class="text-red-600 font-semibold">tidak dapat dibatalkan</span>.
      </p>
      
      <div class="bg-red-50 border border-red-200 text-red-800 p-3 rounded-lg text-xs mb-5 flex items-start space-x-2">
        <span class="text-base leading-none">⚠️</span>
        <span>Semua data terkait, akses login, beserta riwayat dari user ini akan hilang sepenuhnya dari server database.</span>
      </div>

      <div class="mb-6">
        <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wider">
          Ketik ID User <span id="idTargetLabel" class="text-red-600 font-black bg-red-50 px-1.5 py-0.5 rounded border border-red-200"></span> untuk mengonfirmasi:
        </label>
        <input 
          type="text" 
          id="inputKonfirmasiHapus" 
          onkeyup="validasiTeksHapus()"
          placeholder="Masukkan ID Pengguna" 
          class="w-full bg-gray-50 border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 font-mono font-semibold tracking-wide"
          autocomplete="off"
        >
      </div>

      <div class="flex space-x-3 justify-end text-sm font-semibold">
        <button 
          type="button" 
          onclick="tutupModalHapus()" 
          class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-all border border-gray-200"
        >
          Batal
        </button>
        <a 
          id="linkEksekusiHapus" 
          href="#" 
          class="px-4 py-2 bg-gray-200 text-gray-400 rounded-lg pointer-events-none cursor-not-allowed transition-all inline-flex items-center shadow-sm"
        >
          Hapus Selamanya
        </a>
      </div>
    </div>
  </div>

  <script>
    let userIdYangAkanDihapus = null;

    function bukaModalHapus(id, username) {
      userIdYangAkanDihapus = id;
      document.getElementById("namaUserModal").innerText = username;
      // Menampilkan teks panduan ID yang harus diketik user di label modal
      document.getElementById("idTargetLabel").innerText = id;
      document.getElementById("modalHapus").classList.remove("hidden");
      document.getElementById("inputKonfirmasiHapus").focus();
    }

    function tutupModalHapus() {
      document.getElementById("modalHapus").classList.add("hidden");
      document.getElementById("inputKonfirmasiHapus").value = "";
      
      const btnHapus = document.getElementById("linkEksekusiHapus");
      btnHapus.classList.remove("bg-red-600", "text-white", "hover:bg-red-700", "shadow-md");
      btnHapus.classList.add("bg-gray-200", "text-gray-400", "pointer-events-none", "cursor-not-allowed");
      btnHapus.href = "#";
      userIdYangAkanDihapus = null;
    }

    function validasiTeksHapus() {
      const textInput = document.getElementById("inputKonfirmasiHapus").value;
      const btnHapus = document.getElementById("linkEksekusiHapus");

      if (textInput.trim() === String(userIdYangAkanDihapus)) {
        btnHapus.classList.remove("bg-gray-200", "text-gray-400", "pointer-events-none", "cursor-not-allowed");
        btnHapus.classList.add("bg-red-600", "text-white", "hover:bg-red-700", "shadow-md", "shadow-red-200");
        btnHapus.href = `/delete-user/${userIdYangAkanDihapus}`;
      } else {
        btnHapus.classList.remove("bg-red-600", "text-white", "hover:bg-red-700", "shadow-md", "shadow-red-200");
        btnHapus.classList.add("bg-gray-200", "text-gray-400", "pointer-events-none", "cursor-not-allowed");
        btnHapus.href = "#";
      }
    }

    function searchTable() {
      const input = document.getElementById("searchInput");
      const clearBtn = document.getElementById("clearSearch");
      const filter = input.value.toLowerCase();
      
      if (input.value.length > 0) {
        clearBtn.classList.remove('hidden');
      } else {
        clearBtn.classList.add('hidden');
      }

      const table = document.querySelector("table tbody");
      const tr = table.getElementsByTagName("tr");

      for (let i = 0; i < tr.length; i++) {
        let match = false;
        const td = tr[i].getElementsByTagName("td");

        for (let j = 0; j < td.length; j++) {
          if (td[j]) {
            const textValue = td[j].textContent || td[j].innerText;
            if (textValue.toLowerCase().indexOf(filter) > -1) {
              match = true;
              break;
            }
          }
        }
        tr[i].style.display = match ? "" : "none";
      }
    }

    function clearInput() {
      const input = document.getElementById("searchInput");
      input.value = "";
      searchTable();
      input.focus(); 
    }
  </script>
</body>
</html>