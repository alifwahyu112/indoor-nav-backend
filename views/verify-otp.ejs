<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verifikasi PIN OTP</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen">
  <div class="bg-white p-8 rounded-xl shadow-md max-w-md w-full mx-4">
    <h2 class="text-2xl font-bold text-center text-gray-800 mb-2">Verifikasi PIN</h2>
    <p class="text-sm text-gray-500 text-center mb-6">Kode PIN verifikasi telah dikirim ke email Anda. Silakan cek kotak masuk atau spam.</p>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-600 p-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>

    <div class="text-center mb-4">
      <p class="text-sm text-gray-600">Sisa waktu verifikasi Anda:</p>
      <span id="countdown" class="text-xl font-bold text-amber-600">05:00</span>
    </div>

    <form action="/verify-otp" method="POST" class="space-y-4" id="otpForm">
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1">Masukkan 6 Digit PIN</label>
        <input type="text" id="otpInput" name="otp" maxlength="6" placeholder="123456" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-center text-xl font-mono tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-500" required autocomplete="off">
      </div>
      <button type="submit" id="submitBtn" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 rounded-lg transition">Verifikasi PIN</button>
    </form>

    <div id="resendArea" class="hidden text-center mt-6 border-t pt-4">
      <p class="text-xs text-gray-500 mb-2">Tidak menerima kode atau token sudah kadaluwarsa?</p>
      <a href="/forgot-password" class="inline-block bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition shadow-sm">
        Kirim Ulang PIN Baru
      </a>
    </div>
  </div>

  <script>
    // Atur durasi waktu mundur (300 detik = 5 menit)
    let timeRemaining = 30; 
    const countdownElement = document.getElementById('countdown');
    const otpInput = document.getElementById('otpInput');
    const submitBtn = document.getElementById('submitBtn');
    const resendArea = document.getElementById('resendArea');

    const timerInterval = setInterval(() => {
      // Hitung menit dan detik
      let minutes = Math.floor(timeRemaining / 60);
      let seconds = timeRemaining % 60;

      // Tambahkan angka 0 di depan jika di bawah 10 agar formatnya tetap 00:00
      minutes = minutes < 10 ? '0' + minutes : minutes;
      seconds = seconds < 10 ? '0' + seconds : seconds;

      // Update tampilan teks di layar
      countdownElement.textContent = `${minutes}:${seconds}`;

      // Efek visual jika waktu mau habis (di bawah 1 menit berubah jadi merah gari-gari)
      if (timeRemaining <= 60) {
        countdownElement.className = "text-xl font-bold text-red-600 animate-pulse";
      }

      // Jika waktu habis total
      if (timeRemaining <= 0) {
        clearInterval(timerInterval);
        countdownElement.textContent = "WAKTU HABIS";
        countdownElement.className = "text-xl font-bold text-red-600";
        
        // Kunci input dan tombol form
        otpInput.disabled = true;
        otpInput.placeholder = "KADALUWARSA";
        otpInput.className = "w-full bg-gray-100 border border-gray-300 rounded-lg px-3 py-2 text-center text-xl text-gray-400 font-mono tracking-widest focus:outline-none";
        
        submitBtn.disabled = true;
        submitBtn.className = "w-full bg-gray-400 text-gray-200 font-bold py-2 rounded-lg cursor-not-allowed";

        // Munculkan opsi kirim ulang PIN baru secara interaktif
        resendArea.classList.remove('hidden');
      }

      timeRemaining--;
    }, 1000);
  </script>
</body>
</html>