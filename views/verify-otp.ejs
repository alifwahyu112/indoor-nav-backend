<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verifikasi PIN OTP</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen">
  <div class="bg-white p-8 rounded-xl shadow-md max-w-md w-full mx-4">
    <h2 class="text-2xl font-bold text-center text-gray-800 mb-2">Verifikasi PIN</h2>
    <p class="text-sm text-gray-500 text-center mb-6">Kode PIN verifikasi telah dikirim ke email Anda. Silakan cek kotak masuk atau spam.</p>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-600 p-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>

    <form action="/verify-otp" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1">Masukkan 6 Digit PIN</label>
        <input type="text" name="otp" maxlength="6" placeholder="123456" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-center text-xl font-mono tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-500" required autocomplete="off">
      </div>
      <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 rounded-lg transition">Verifikasi PIN</button>
    </form>
  </div>
</body>
</html>