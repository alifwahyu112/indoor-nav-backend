<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800">

  <div class="flex h-screen overflow-hidden">

    <aside class="w-64 bg-white shadow-md flex flex-col z-10">
      <div class="p-6 border-b border-gray-200">
        <h1 class="text-2xl font-bold text-blue-600">Dashboard</h1>
      </div>

      <nav class="flex-1 p-4 space-y-2">
        <a href="/" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">👤 Data User</a>
        <a href="/riwayat_perjalanan" class="block py-2 px-3 rounded-md bg-blue-100 text-blue-700 font-medium">📍 Riwayat</a>
        <a href="/map" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">🗺️ Map</a>
        <a href="/admin" class="block py-2 px-3 rounded-md hover:bg-blue-100 font-medium">🔑 Admin</a>
      </nav>

      <div class="p-4 border-t border-gray-200">
        <a href="/logout" class="text-red-500 hover:underline font-medium">Logout</a>
      </div>
    </aside>

    <main class="flex-1 h-full overflow-y-auto p-6 bg-gray-100">
      
      <header class="flex items-center justify-between mb-6">
        <h2 class="text-3xl font-semibold"><%= title %></h2>

        <div class="relative w-64 md:w-80">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </span>
          <input type="text" id="searchInput" onkeyup="searchTable()" placeholder="Cari data riwayat..." class="block w-full pl-10 pr-10 py-2 border border-gray-300 rounded-md leading-5 bg-white placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-blue-500 sm:text-sm">
          <button id="clearSearch" onclick="clearInput()" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 hidden">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </header>

      <div class="mt-8 bg-white p-6 rounded-lg shadow mb-10"> 
        <h3 class="text-2xl font-semibold mb-4">Daftar Data Riwayat Perjalanan</h3>
        
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-gray-200 text-sm">
            <thead>
              <tr class="bg-blue-50 text-left">
                <th class="border px-4 py-2">ID</th>
                <th class="border px-4 py-2">Nama Pengguna</th>
                <th class="border px-4 py-2">Mulai (Scan QR)</th>
                <th class="border px-4 py-2">Tujuan</th>
                <th class="border px-4 py-2">Tanggal</th>
                <th class="border px-4 py-2 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (riwayat_perjalanans && riwayat_perjalanans.length > 0) { %>
                <% riwayat_perjalanans.forEach((row) => { %>
                  <tr class="hover:bg-gray-50">
                    <td class="border px-4 py-2 font-bold"><%= row.id %></td>
                    
                    <td class="border px-4 py-2 text-blue-600 font-bold capitalize">
                      <%= row.username ? row.username : "User Tidak Dikenal" %>
                    </td>
                    
                    <td class="border px-4 py-2">
                      <% 
                        let textMulai = row.mulai ? row.mulai.toString() : "";
                        let txtKoorAwal = row.koordinat_awal ? row.koordinat_awal.toString() : "";
                        
                        if (textMulai.indexOf("(") !== -1) {
                          let splitIndex = textMulai.indexOf("(");
                          txtKoorAwal = textMulai.substring(splitIndex); 
                          textMulai = textMulai.substring(0, splitIndex).trim(); 
                        }
                        
                        if (txtKoorAwal) {
                           txtKoorAwal = txtKoorAwal.replace("(", "").replace(")", "").trim();
                        }
                      %>
                      <span class="font-semibold text-gray-800"><%= textMulai %></span> 
                      <% if (txtKoorAwal && txtKoorAwal !== "-") { %>
                        <br>
                        <span class="text-xs text-gray-500 font-mono mt-0.5">(<%= txtKoorAwal %>)</span>
                      <% } %>
                    </td>
                    
                    <td class="border px-4 py-2">
                      <% 
                        let textTujuan = row.tujuan ? row.tujuan.toString() : "";
                        let txtKoorTujuan = row.koordinat_tujuan ? row.koordinat_tujuan.toString() : "";
                        
                        if (textTujuan.indexOf("(") !== -1) {
                          let splitIdx = textTujuan.indexOf("(");
                          txtKoorTujuan = textTujuan.substring(splitIdx);
                          textTujuan = textTujuan.substring(0, splitIdx).trim();
                        }
                        
                        if (txtKoorTujuan) {
                           txtKoorTujuan = txtKoorTujuan.replace("(", "").replace(")", "").trim();
                        }
                      %>
                      <span class="font-semibold text-gray-800"><%= textTujuan %></span>
                      <% if (txtKoorTujuan && txtKoorTujuan !== "-") { %>
                        <br>
                        <span class="text-xs text-gray-500 font-mono mt-0.5">(<%= txtKoorTujuan %>)</span>
                      <% } %>
                    </td>

                    <td class="border px-4 py-2">
                      <%= new Date(row.tanggal).toLocaleString('id-ID') %>
                    </td>
                    <td class="border px-4 py-2 text-center">
                      <button type="button" onclick="bukaModalHapus('/delete-riwayat_perjalanan/<%= row.id %>')" class="bg-red-100 text-red-600 px-3 py-1 rounded-md hover:bg-red-200 text-xs font-semibold">Hapus</button>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center py-10 text-gray-500 italic">Belum ada data riwayat perjalanan.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <div id="modalHapus" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-gray-900 bg-opacity-40 backdrop-blur-sm" onclick="tutupModalHapus()"></div>
    <div class="bg-white text-gray-800 rounded-xl shadow-2xl max-w-sm w-full mx-4 p-6 relative z-10 border border-gray-200">
      <div class="flex items-center space-x-3 text-red-600 mb-3">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
        <h3 class="text-lg font-bold tracking-tight">Hapus Data Riwayat</h3>
      </div>
      <p class="text-gray-600 text-sm mb-6 leading-relaxed">
        Apakah Anda yakin ingin menghapus data riwayat perjalanan ini secara permanen dari server?
      </p>
      <div class="flex space-x-3 justify-end text-sm font-semibold">
        <button type="button" onclick="tutupModalHapus()" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition border border-gray-200">Batal</button>
        <a id="linkEksekusiHapus" href="#" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition shadow-md shadow-red-200">Hapus Selamanya</a>
      </div>
    </div>
  </div>

  <script>
    function bukaModalHapus(urlDelete) {
      document.getElementById("linkEksekusiHapus").href = urlDelete;
      document.getElementById("modalHapus").classList.remove("hidden");
    }
    function tutupModalHapus() {
      document.getElementById("modalHapus").classList.add("hidden");
      document.getElementById("linkEksekusiHapus").href = "#";
    }

    function searchTable() {
      const input = document.getElementById("searchInput");
      const clearBtn = document.getElementById("clearSearch");
      const filter = input.value.toLowerCase();
      input.value.length > 0 ? clearBtn.classList.remove('hidden') : clearBtn.classList.add('hidden');
      const table = document.querySelector("table tbody");
      const tr = table.getElementsByTagName("tr");
      for (let i = 0; i < tr.length; i++) {
        if (tr[i].cells.length < 2) continue;
        let match = false;
        const td = tr[i].getElementsByTagName("td");
        for (let j = 0; j < td.length; j++) {
          if (td[j]) {
            const textValue = td[j].textContent || td[j].innerText;
            if (textValue.toLowerCase().indexOf(filter) > -1) {
              match = true;
              break;
            }
          }
        }
        tr[i].style.display = match ? "" : "none";
      }
    }
    function clearInput() {
      const input = document.getElementById("searchInput");
      input.value = "";
      searchTable();
      input.focus();
    }
  </script>
</body>
</html>